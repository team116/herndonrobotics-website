---
import { withBase } from "../utils/url";
import {social_links} from "../utils/socials"

const navItemClass =
  "text-2xl hover:text-primary underline underline-offset-4 decoration-transparent hover:decoration-primary transition-colors duration-200";

  
const sections = [
  {
    label: "About Us",
    items: [
      { title: "Who are we?", href: "/about-us#WhoAreWe", desc: "What is Herndon Robotics and what do we stand for?" },
      { title: "Portfolio", href: "/about-us#portfolio", desc: "What we've done over the years." },
      { title: "Team Members", href: "/about-us#team-members", desc: "Mentors + Students" },
      { title: "Sponsors", href: "/about-us#sponsors", desc: "Who supports us?" },
    ],
  },
  {
    label: "Getting Involved",
    items: [
      { title: "Joining The Club", href: "/getting-involved#new-member", desc: "For any HHS students looking to join the Herndon Robotics Club and grow their STEM expertise." },
      { title: "Mentorship", href: "/getting-involved#new-mentors", desc: "Become a mentor for Herndon Robotics and help guide the next generation." },
      { title: "Plan Outreach", href: "/getting-involved#plan-outreach", desc: "Do you want us to show off our robots at one of your events?" },
      { title: "Sponsor Us", href: "/getting-involved#new-sponsor", desc: "Support our team through monetary or other means." },
    ],
  },
  {
    label: "Current Members",
    items: [
      { title: "Meetings/Events", href: "/current-member#calendar", desc: "What events do we have coming up? When are meetings? Do we have a meeting today?" },
      { title: "Forms", href: "/current-member#forms", desc: "Forms for field trips, emergency care, and instructions on how to join our FIRST team." },
      { title: "Training Materials", href: "/current-member#resources", desc: "Want to grow your skills? look here." },
    ],
  },
];


---

<div class="px-4 py-2 bg-muted border border-border flex flex-row justify-between max-w-full w-full font-audiowide">
  <!-- Team Logo & Name -->
  <div class="flex flex-row gap-4 w-min">
    <h1 class="text-5xl content-center font-bold w-max tracking-tighter text-center">Epsilon<br>Delta</h1>
    
    <img src={withBase("logo.png")} class="h-24 w-auto object-contain"></img>
    
    <div class="grid grid-cols-3 h-full grid-rows-2 aspect-3/2 gap-1" id="socials">
      {social_links.map((social) => (
        <a 
          href={social.link}
          class="flex items-center justify-center bg-foreground m-0.5 aspect-square items-center"
          style={
            `mask-image: url('${social.social}');
            mask-size: contain;
            mask-repeat: no-repeat;
            mask-position: center;`
          }></a>
      ))}
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex max-w-max flex-1 items-center justify-center px-4 py-4 gap-4" aria-label="Main">
    <a href={withBase('/')} class={navItemClass}>Home</a>

    {sections.map((section) => (
      <div
        class="relative"
        x-data="{open: false}"
        @keydown.escape="open = false"
        @click.outside="open = false"
      >
        <div class="flex flex-row items-center gap-0.5">
          <button
            type="button"
            x-ref="button"
            class={navItemClass}
            :aria-expanded="open"
            @click="open = !open"
          >
            {section.label}
          </button>
          <svg class="size-5 transition-transform" :class="open && 'rotate-180'" xmlns="http://www.w3.org/2000/svg"  fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
          </svg>
        </div>
        <template x-if="true">
          <ul
            x-show="open"
            x-transition
            class="absolute top-full mt-2 w-80 max-w-[calc(100vw-2rem)] bg-popover border border-border shadow-lg p-2 z-50 bg-background"
            x-anchor.bottom-start="$refs.button"
          >
            {section.items.map((item) => (
              <li>
                <a href={withBase(item.href)} class="group block px-3 py-2 hover:bg-primary hover:text-accent-foreground transition-all duration-300">
                  <div class="text-base font-medium">{item.title}</div>
                  <p class="text-base text-muted-foreground group-hover:text-accent-foreground">{item.desc}</p>
                </a>
              </li>
            ))}
          </ul>
        </template>
      </div>
    ))}
    <a href={withBase('/blog')} class={navItemClass}>Blog</a>
  </nav>
</div>
