---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  entry: CollectionEntry<"portfolio">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;
---

<div class="border border-accent rounded-2xl p-4 bg-secondary">
  <Image src={data.img} alt={data.robot_name} />
  <div class="flex flex-col gap-1 items-center">
    <h3 class="text-lg font-semibold font-audiowide">{data.robot_name}</h3>
    <p class="text-shadow-md text-primary">
      {data.competition_type} &middot; {data.year} &middot; {data.title}
    </p>
  </div>

  <div class="content">
    <Content />
  </div>
</div>

<style>
  .content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin-top: 1rem;
  }

  .content :global(th),
  .content :global(td) {
    border: 1px solid;
    padding: 0.5rem;
    text-align: left;
  }

  .content :global(th) {
    font-weight: 600;
  }
</style>