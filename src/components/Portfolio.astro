---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  entry: CollectionEntry<"portfolio">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data, id } = entry;
---

<a href={"/portfolio/" + id } class="group">
  <div class="border border-accent rounded-2xl p-4 bg-secondary flex flex-col transition-all group-hover:bg-background group-hover:p-6 ">
    <Image src={data.img} alt={data.robot_name} class="self-center w-full rounded-2xl" />
    <div class="flex flex-col gap-1 items-center">
      <h3 class="text-2xl font-semibold font-audiowide">{data.robot_name}</h3>
      <p class="text-shadow-md text-primary text-lg">
        {data.competition_type} &middot; {data.year} &middot; {data.title}
      </p>
    </div>

    <!-- <div class="content">
    <Content />
  </div> -->
  </div>
</a>

