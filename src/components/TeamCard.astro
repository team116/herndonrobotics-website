---
// src/components/TeamCard.astro
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  href: string;
  image: ImageMetadata;
  imageAlt: string;
  title: string;
  description: string;
}

const { href, image, imageAlt, title, description } = Astro.props;
---
<a href={href}>
  <div
    class="ring-1 ring-accent rounded-2xl p-8 bg-secondary w-full transition-all hover:ring-4 grid grid-cols-2 gap-4"
  >
    <Image
      src={image}
      alt={imageAlt}
      class="self-center aspect-square w-auto rounded-2xl"
    />

    <div
      class="flex flex-col flex-1 p-4 py-8 border border-accent rounded-2xl bg-background gap-4"
    >
      <p
        class="text-5xl font-semibold font-audiowide w-full text-center text-primary"
      >
        {title}
      </p>
      <div class="text-2xl text-foreground">
        <p>{description}</p>
      </div>
    </div>
  </div>
</a>