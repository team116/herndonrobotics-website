---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Current Member">
  <div class="p-8 gap-12 flex flex-col">
    <section id="calendar">
      <div class="flex flex-col flex-1 justify-center">
        <h2 class="text-6xl font-audiowide mb-4 text-primary-foreground">
          <i>Calendar</i>
        </h2>
      </div>
      <iframe
        src="https://calendar.google.com/calendar/embed?src=c_c5500f600227051e9a84741368561a20b440914798871e717326cab71ee08e0c%40group.calendar.google.com&ctz=America%2FNew_York&showTitle=0&showPrint=0&showTabs=0&showCalendars=0&showTz=0"
        style="border: 0"
        class="w-full h-full rounded-2xl aspect-video bg-accent"></iframe>
    </section>
  </div>
</Layout>
